        },
        {
          "id": 7,
          "title": "7. Add error handling for storage operations",
          "description": "Implement a robust error handling system for all storage-related operations to ensure data integrity and provide clear feedback.",
          "details": "1. Design a comprehensive exception hierarchy:\n   - ProfileStorageError as base class\n   - ProfileNotFoundError for missing profiles\n   - ProfileValidationError for invalid data\n   - ProfileStorageConnectionError for backend issues\n   - ProfileConcurrencyError for conflict detection\n   - ProfileCorruptionError for data integrity issues\n2. Implement error recovery strategies:\n   - Automatic retries for transient errors\n   - Fallback to backup storage when primary fails\n   - Data recovery from backup files\n3. Add detailed logging for all errors with context information\n4. Create user-friendly error messages with actionable advice\n5. Implement transaction management with rollback capabilities\n6. Add diagnostic tools for storage health checks\n7. Create error aggregation and reporting mechanisms\n8. Implement circuit breaker pattern for unstable storage\n9. Add telemetry for error frequency and patterns\n\n<info added on 2025-05-04T02:47:26.760Z>\nHere's additional implementation information for the error handling system:\n\n## Error Handling Implementation Details\n\n### Exception Handling Patterns\n```python\ndef safe_storage_operation(operation_name):\n    \"\"\"Decorator for wrapping storage operations with standardized error handling\"\"\"\n    def decorator(func):\n        @functools.wraps(func)\n        def wrapper(*args, **kwargs):\n            try:\n                return func(*args, **kwargs)\n            except sqlite3.OperationalError as e:\n                if \"database is locked\" in str(e):\n                    # Implement exponential backoff retry\n                    for attempt in range(3):\n                        time.sleep(0.5 * (2 ** attempt))\n                        try:\n                            return func(*args, **kwargs)\n                        except Exception:\n                            continue\n                    raise ProfileConcurrencyError(f\"Database locked during {operation_name}\")\n                elif \"no such table\" in str(e):\n                    raise ProfileCorruptionError(f\"Database schema issue: {e}\")\n                else:\n                    raise ProfileStorageConnectionError(f\"Database operation failed: {e}\")\n            except Exception as e:\n                # Log unexpected errors\n                logging.error(f\"Unexpected error in {operation_name}: {e}\", exc_info=True)\n                raise\n        return wrapper\n    return decorator\n```\n\n### Circuit Breaker Implementation\n```python\nclass StorageCircuitBreaker:\n    def __init__(self, failure_threshold=5, reset_timeout=60):\n        self.failure_count = 0\n        self.failure_threshold = failure_threshold\n        self.reset_timeout = reset_timeout\n        self.last_failure_time = 0\n        self.state = \"CLOSED\"  # CLOSED, OPEN, HALF-OPEN\n        self.lock = threading.RLock()\n    \n    def execute(self, func, *args, **kwargs):\n        with self.lock:\n            current_time = time.time()\n            if self.state == \"OPEN\":\n                if current_time - self.last_failure_time > self.reset_timeout:\n                    self.state = \"HALF-OPEN\"\n                else:\n                    raise ProfileStorageConnectionError(\"Circuit breaker open - storage system unavailable\")\n            \n            try:\n                result = func(*args, **kwargs)\n                if self.state == \"HALF-OPEN\":\n                    self.state = \"CLOSED\"\n                    self.failure_count = 0\n                return result\n            except (ProfileStorageConnectionError, ProfileCorruptionError) as e:\n                self.failure_count += 1\n                self.last_failure_time = current_time\n                if self.failure_count >= self.failure_threshold:\n                    self.state = \"OPEN\"\n                raise\n```\n\n### Error Telemetry System\n```python\nclass ErrorTelemetry:\n    def __init__(self):\n        self.error_counts = defaultdict(int)\n        self.error_timestamps = defaultdict(list)\n        self.lock = threading.RLock()\n    \n    def record_error(self, error_type, context=None):\n        with self.lock:\n            self.error_counts[error_type] += 1\n            self.error_timestamps[error_type].append(time.time())\n            # Trim old timestamps (keep last 100)\n            if len(self.error_timestamps[error_type]) > 100:\n                self.error_timestamps[error_type] = self.error_timestamps[error_type][-100:]\n    \n    def get_error_rate(self, error_type, time_window=300):\n        \"\"\"Get error rate for specified type in last time_window seconds\"\"\"\n        with self.lock:\n            now = time.time()\n            recent_errors = [t for t in self.error_timestamps[error_type] \n                            if now - t <= time_window]\n            return len(recent_errors)\n    \n    def get_report(self):\n        \"\"\"Generate error summary report\"\"\"\n        with self.lock:\n            return {\n                \"counts\": dict(self.error_counts),\n                \"rates\": {\n                    err_type: self.get_error_rate(err_type)\n                    for err_type in self.error_counts\n                }\n            }\n```\n\n### Data Recovery Strategy\n```python\ndef recover_profile_data(profile_id):\n    \"\"\"Attempt to recover corrupted profile data\"\"\"\n    # Try primary backup\n    try:\n        backup_path = f\"backups/profiles/{profile_id}.json\"\n        if os.path.exists(backup_path):\n            with open(backup_path, 'r') as f:\n                profile_data = json.load(f)\n                # Validate recovered data\n                if validate_profile_schema(profile_data):\n                    return profile_data\n    except Exception as e:\n        logging.warning(f\"Failed to recover from primary backup: {e}\")\n    \n    # Try point-in-time backups (last 5 days)\n    for days_ago in range(1, 6):\n        try:\n            date_str = (datetime.now() - timedelta(days=days_ago)).strftime(\"%Y%m%d\")\n            backup_path = f\"backups/profiles/archive/{date_str}/{profile_id}.json\"\n            if os.path.exists(backup_path):\n                with open(backup_path, 'r') as f:\n                    profile_data = json.load(f)\n                    if validate_profile_schema(profile_data):\n                        return profile_data\n        except Exception as e:\n            logging.warning(f\"Failed to recover from {days_ago}-day backup: {e}\")\n    \n    # If all recovery attempts fail\n    raise ProfileCorruptionError(f\"Unable to recover data for profile {profile_id}\")\n```\n\n### Storage Health Check\n```python\ndef perform_storage_health_check():\n    \"\"\"Diagnostic tool to verify storage system health\"\"\"\n    results = {\n        \"status\": \"healthy\",\n        \"issues\": []\n    }\n    \n    # Check database connection\n    try:\n        conn = get_db_connection()\n        conn.execute(\"SELECT 1\")\n        conn.close()\n    except Exception as e:\n        results[\"status\"] = \"unhealthy\"\n        results[\"issues\"].append(f\"Connection error: {str(e)}\")\n    \n    # Check database integrity\n    try:\n        conn = get_db_connection()\n        integrity_check = conn.execute(\"PRAGMA integrity_check\").fetchone()[0]\n        if integrity_check != \"ok\":\n            results[\"status\"] = \"unhealthy\"\n            results[\"issues\"].append(f\"Integrity check failed: {integrity_check}\")\n        conn.close()\n    except Exception as e:\n        results[\"status\"] = \"unhealthy\"\n        results[\"issues\"].append(f\"Integrity check error: {str(e)}\")\n    \n    # Check backup system\n    try:\n        if not os.path.exists(\"backups/profiles\"):\n            results[\"status\"] = \"degraded\"\n            results[\"issues\"].append(\"Backup directory not found\")\n    except Exception as e:\n        results[\"status\"] = \"degraded\"\n        results[\"issues\"].append(f\"Backup check error: {str(e)}\")\n    \n    return results\n```\n</info added on 2025-05-04T02:47:26.760Z>\n\n<info added on 2025-05-04T04:26:12.856Z>\n## Error Handling Implementation Progress\n\n### Exception Hierarchy Implementation\n```python\n# src/exceptions.py\nclass ProfileStorageError(Exception):\n    \"\"\"Base exception for all profile storage errors\"\"\"\n    pass\n\nclass ProfileNotFoundError(ProfileStorageError):\n    \"\"\"Raised when a profile cannot be found\"\"\"\n    pass\n\nclass ProfileValidationError(ProfileStorageError):\n    \"\"\"Raised when profile data fails validation\"\"\"\n    pass\n\nclass ProfileStorageConnectionError(ProfileStorageError):\n    \"\"\"Raised when there are issues connecting to storage\"\"\"\n    pass\n\nclass ProfileConcurrencyError(ProfileStorageError):\n    \"\"\"Raised when concurrent operations conflict\"\"\"\n    pass\n\nclass ProfileCorruptionError(ProfileStorageError):\n    \"\"\"Raised when profile data is corrupted or invalid\"\"\"\n    pass\n```\n\n### Database Error Handling Implementation\n```python\n# src/profile_repository.py\nimport functools\nimport logging\nimport sqlite3\nfrom .exceptions import *\n\ndef map_sqlite_exception(e):\n    \"\"\"Maps SQLite exceptions to custom exception types\"\"\"\n    error_msg = str(e).lower()\n    if \"no such table\" in error_msg:\n        return ProfileCorruptionError(f\"Database schema issue: {e}\")\n    elif \"database is locked\" in error_msg:\n        return ProfileConcurrencyError(f\"Database locked: {e}\")\n    elif \"disk i/o error\" in error_msg or \"unable to open database\" in error_msg:\n        return ProfileStorageConnectionError(f\"Database connection failed: {e}\")\n    elif \"constraint failed\" in error_msg:\n        return ProfileValidationError(f\"Data constraint violation: {e}\")\n    else:\n        return ProfileStorageError(f\"Database error: {e}\")\n\ndef handle_db_errors(func):\n    \"\"\"Decorator to handle database errors consistently\"\"\"\n    @functools.wraps(func)\n    def wrapper(*args, **kwargs):\n        try:\n            return func(*args, **kwargs)\n        except sqlite3.Error as e:\n            logging.error(f\"Database error in {func.__name__}: {e}\", exc_info=True)\n            raise map_sqlite_exception(e)\n        except json.JSONDecodeError as e:\n            logging.error(f\"JSON decode error in {func.__name__}: {e}\", exc_info=True)\n            raise ProfileCorruptionError(f\"Invalid JSON data: {e}\")\n        except Exception as e:\n            logging.error(f\"Unexpected error in {func.__name__}: {e}\", exc_info=True)\n            raise\n    return wrapper\n```\n\n### Example Repository Method Implementation\n```python\nclass ProfileRepository:\n    # ...\n    \n    @handle_db_errors\n    def get_profile(self, profile_id):\n        \"\"\"Get a profile by ID with robust error handling\"\"\"\n        cursor = self.conn.cursor()\n        cursor.execute(\"SELECT data FROM profiles WHERE id = ?\", (profile_id,))\n        row = cursor.fetchone()\n        \n        if not row:\n            raise ProfileNotFoundError(f\"Profile with ID {profile_id} not found\")\n            \n        try:\n            profile_data = json.loads(row[0])\n            return profile_data\n        except json.JSONDecodeError as e:\n            raise ProfileCorruptionError(f\"Corrupted profile data for ID {profile_id}: {e}\")\n    \n    @handle_db_errors\n    def save_profile(self, profile_id, profile_data):\n        \"\"\"Save a profile with error handling\"\"\"\n        # Validate profile data before saving\n        if not self._validate_profile(profile_data):\n            raise ProfileValidationError(f\"Invalid profile data for ID {profile_id}\")\n            \n        try:\n            serialized_data = json.dumps(profile_data)\n            cursor = self.conn.cursor()\n            cursor.execute(\n                \"INSERT OR REPLACE INTO profiles (id, data, updated_at) VALUES (?, ?, ?)\",\n                (profile_id, serialized_data, datetime.now().isoformat())\n            )\n            self.conn.commit()\n            return True\n        except Exception as e:\n            self.conn.rollback()\n            raise\n```\n</info added on 2025-05-04T04:26:12.856Z>\n\n<info added on 2025-05-04T05:06:07.566Z>\n## Retry Logic Implementation for Database Lock Errors\n\n```python\n# src/profile_repository.py\nimport time\n\ndef handle_db_errors(func):\n    \"\"\"Decorator to handle database errors with retry logic for locks\"\"\"\n    @functools.wraps(func)\n    def wrapper(*args, **kwargs):\n        max_retries = 3\n        retry_count = 0\n        \n        while True:\n            try:\n                return func(*args, **kwargs)\n            except sqlite3.OperationalError as e:\n                error_msg = str(e).lower()\n                if \"database is locked\" in error_msg and retry_count < max_retries:\n                    # Exponential backoff for database locks\n                    retry_count += 1\n                    wait_time = 0.2 * (2 ** (retry_count - 1))\n                    logging.warning(\n                        f\"Database locked, retrying in {wait_time:.2f}s (attempt {retry_count}/{max_retries})\"\n                    )\n                    time.sleep(wait_time)\n                    continue\n                else:\n                    logging.error(f\"Database error in {func.__name__}: {e}\", exc_info=True)\n                    raise map_sqlite_exception(e)\n            except sqlite3.Error as e:\n                logging.error(f\"Database error in {func.__name__}: {e}\", exc_info=True)\n                raise map_sqlite_exception(e)\n            except json.JSONDecodeError as e:\n                logging.error(f\"JSON decode error in {func.__name__}: {e}\", exc_info=True)\n                raise ProfileCorruptionError(f\"Invalid JSON data: {e}\")\n            except Exception as e:\n                logging.error(f\"Unexpected error in {func.__name__}: {e}\", exc_info=True)\n                raise\n    return wrapper\n```\n\n### Usage Statistics for Lock Monitoring\n\n```python\nclass DatabaseLockMonitor:\n    def __init__(self):\n        self.lock_events = []\n        self.lock = threading.RLock()\n        \n    def record_lock_event(self, operation_name, retry_count):\n        with self.lock:\n            self.lock_events.append({\n                \"timestamp\": time.time(),\n                \"operation\": operation_name,\n                \"retries\": retry_count\n            })\n            # Keep only the last 100 events\n            if len(self.lock_events) > 100:\n                self.lock_events = self.lock_events[-100:]\n    \n    def get_lock_frequency(self, time_window=300):\n        \"\"\"Get number of lock events in the last time_window seconds\"\"\"\n        with self.lock:\n            now = time.time()\n            recent_locks = [e for e in self.lock_events \n                           if now - e[\"timestamp\"] <= time_window]\n            return len(recent_locks)\n            \n    def get_problematic_operations(self):\n        \"\"\"Identify operations with the most lock conflicts\"\"\"\n        with self.lock:\n            operation_counts = {}\n            for event in self.lock_events:\n                op = event[\"operation\"]\n                operation_counts[op] = operation_counts.get(op, 0) + 1\n            return sorted(operation_counts.items(), key=lambda x: x[1], reverse=True)\n```\n</info added on 2025-05-04T05:06:07.566Z>\n\n<info added on 2025-05-04T06:37:01.676Z>\n## Storage Health Check Implementation\n\n```python\n# src/profile_repository.py\nimport os\nimport logging\n\nclass ProfileRepository:\n    # ... existing methods ...\n    \n    def perform_storage_health_check(self):\n        \"\"\"\n        Performs comprehensive health check on the storage system\n        Returns a dictionary with health status information\n        \"\"\"\n        results = {\n            \"status\": \"healthy\",\n            \"issues\": [],\n            \"checks_performed\": []\n        }\n        \n        # Check 1: Database connection\n        try:\n            cursor = self.conn.cursor()\n            cursor.execute(\"SELECT 1\")\n            cursor.fetchone()\n            results[\"checks_performed\"].append(\"connection\")\n            logging.info(\"Storage health check: Database connection successful\")\n        except Exception as e:\n            results[\"status\"] = \"unhealthy\"\n            results[\"issues\"].append(f\"Connection error: {str(e)}\")\n            logging.error(f\"Storage health check: Connection error - {str(e)}\")\n        \n        # Check 2: Database integrity\n        try:\n            cursor = self.conn.cursor()\n            integrity_result = cursor.execute(\"PRAGMA integrity_check\").fetchone()[0]\n            results[\"checks_performed\"].append(\"integrity\")\n            \n            if integrity_result != \"ok\":\n                results[\"status\"] = \"unhealthy\"\n                results[\"issues\"].append(f\"Integrity check failed: {integrity_result}\")\n                logging.error(f\"Storage health check: Integrity check failed - {integrity_result}\")\n            else:\n                logging.info(\"Storage health check: Database integrity verified\")\n        except Exception as e:\n            results[\"status\"] = \"unhealthy\"\n            results[\"issues\"].append(f\"Integrity check error: {str(e)}\")\n            logging.error(f\"Storage health check: Integrity check error - {str(e)}\")\n        \n        # Check 3: Backup directory\n        try:\n            db_path = self.conn.execute(\"PRAGMA database_list\").fetchone()[2]\n            db_dir = os.path.dirname(db_path)\n            backup_dir = os.path.join(db_dir, \"backups\")\n            \n            results[\"checks_performed\"].append(\"backup_directory\")\n            \n            if not os.path.exists(backup_dir):\n                if results[\"status\"] == \"healthy\":\n                    results[\"status\"] = \"degraded\"\n                results[\"issues\"].append(\"Backup directory not found\")\n                logging.warning(\"Storage health check: Backup directory not found\")\n            else:\n                logging.info(\"Storage health check: Backup directory exists\")\n        except Exception as e:\n            if results[\"status\"] == \"healthy\":\n                results[\"status\"] = \"degraded\"\n            results[\"issues\"].append(f\"Backup check error: {str(e)}\")\n            logging.error(f\"Storage health check: Backup check error - {str(e)}\")\n        \n        logging.info(f\"Storage health check complete - Status: {results['status']}\")\n        return results\n```\n</info added on 2025-05-04T06:37:01.676Z>",
