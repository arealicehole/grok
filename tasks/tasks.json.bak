        {
          "id": 4,
          "title": "Implement response parsing and validation",
          "description": "Create functions to parse, validate and store API responses",
          "dependencies": [
            3
          ],
          "details": "1. Implement parse_analysis_response function to extract relevant data from API response\n2. Add JSON schema validation to ensure response matches expected format\n3. Create logic to transform raw API response into structured data format\n4. Implement error handling for malformed responses\n5. Create function to store parsed results in AnalysisResult model\n6. Add data sanitization to handle potential security issues\n7. Implement validation rules for different analysis types\n8. Write unit tests with various response scenarios (valid, invalid, malformed)\n9. Create utility functions for common parsing operations\n\n<info added on 2025-05-20T06:55:45.282Z>\n## Implementation Details for Response Parsing and Validation\n\n### JSON Schema Definition\n```python\n# Example schema for sentiment analysis response\nSENTIMENT_ANALYSIS_SCHEMA = {\n    \"type\": \"object\",\n    \"required\": [\"sentiment\", \"confidence\", \"explanation\"],\n    \"properties\": {\n        \"sentiment\": {\"type\": \"string\", \"enum\": [\"positive\", \"negative\", \"neutral\"]},\n        \"confidence\": {\"type\": \"number\", \"minimum\": 0, \"maximum\": 1},\n        \"explanation\": {\"type\": \"string\"},\n        \"key_phrases\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}}\n    }\n}\n\n# Schema registry to support multiple analysis types\nANALYSIS_SCHEMAS = {\n    \"sentiment\": SENTIMENT_ANALYSIS_SCHEMA,\n    \"topic\": TOPIC_ANALYSIS_SCHEMA,\n    # Add other analysis types as needed\n}\n```\n\n### Response Parser Implementation\n```python\ndef parse_analysis_response(raw_response, analysis_type):\n    \"\"\"\n    Parse and validate API response based on analysis type.\n    \n    Args:\n        raw_response (str or dict): Raw API response\n        analysis_type (str): Type of analysis performed\n        \n    Returns:\n        dict: Validated and structured analysis data\n        \n    Raises:\n        ResponseParsingError: If response cannot be parsed\n        ResponseValidationError: If response fails schema validation\n    \"\"\"\n    try:\n        # Convert string to dict if needed\n        if isinstance(raw_response, str):\n            data = json.loads(raw_response)\n        else:\n            data = raw_response\n            \n        # Extract content from Grok API response structure\n        if \"choices\" in data and len(data[\"choices\"]) > 0:\n            if \"message\" in data[\"choices\"][0] and \"content\" in data[\"choices\"][0][\"message\"]:\n                content = data[\"choices\"][0][\"message\"][\"content\"]\n                \n                # Handle different response formats (JSON string vs structured text)\n                try:\n                    parsed_content = json.loads(content)\n                except json.JSONDecodeError:\n                    # If not JSON, apply text parsing based on analysis type\n                    parsed_content = _parse_text_response(content, analysis_type)\n                \n                # Validate against schema\n                schema = ANALYSIS_SCHEMAS.get(analysis_type)\n                if schema:\n                    jsonschema.validate(parsed_content, schema)\n                \n                # Apply transformations specific to analysis type\n                return _transform_response(parsed_content, analysis_type)\n            \n        raise ResponseParsingError(\"Unable to extract content from API response\")\n    except json.JSONDecodeError as e:\n        raise ResponseParsingError(f\"Invalid JSON format: {str(e)}\")\n    except jsonschema.exceptions.ValidationError as e:\n        raise ResponseValidationError(f\"Response failed schema validation: {str(e)}\")\n```\n\n### Data Sanitization\n```python\ndef _sanitize_response_data(data):\n    \"\"\"\n    Sanitize response data to prevent security issues.\n    \n    Args:\n        data (dict): Parsed response data\n        \n    Returns:\n        dict: Sanitized data\n    \"\"\"\n    sanitized = {}\n    \n    # Recursively process dictionary\n    for key, value in data.items():\n        # Convert keys to snake_case and sanitize\n        safe_key = re.sub(r'[^\\w]', '_', key.lower())\n        \n        if isinstance(value, dict):\n            sanitized[safe_key] = _sanitize_response_data(value)\n        elif isinstance(value, list):\n            sanitized[safe_key] = [\n                _sanitize_response_data(item) if isinstance(item, dict) \n                else html.escape(str(item)) if isinstance(item, str)\n                else item\n                for item in value\n            ]\n        elif isinstance(value, str):\n            # Escape HTML entities to prevent XSS\n            sanitized[safe_key] = html.escape(value)\n        else:\n            # Numbers, booleans, etc. pass through\n            sanitized[safe_key] = value\n            \n    return sanitized\n```\n\n### Error Recovery Strategy\n```python\ndef recover_partial_response(raw_response, analysis_type):\n    \"\"\"\n    Attempt to extract useful data from malformed responses.\n    \n    Args:\n        raw_response (str or dict): Raw API response\n        analysis_type (str): Type of analysis performed\n        \n    Returns:\n        dict: Partially recovered data or empty dict if recovery fails\n    \"\"\"\n    try:\n        # Attempt to extract any JSON-like structures from text\n        if isinstance(raw_response, str):\n            # Find JSON-like patterns using regex\n            json_pattern = r'\\{(?:[^{}]|(?R))*\\}'\n            matches = re.findall(json_pattern, raw_response)\n            \n            for potential_json in matches:\n                try:\n                    data = json.loads(potential_json)\n                    # Check if it has at least some expected keys\n                    schema = ANALYSIS_SCHEMAS.get(analysis_type, {})\n                    required_keys = schema.get(\"required\", [])\n                    \n                    if any(key in data for key in required_keys):\n                        return {\n                            \"recovered_data\": data,\n                            \"is_complete\": False,\n                            \"missing_fields\": [k for k in required_keys if k not in data]\n                        }\n                except:\n                    continue\n                    \n        return {}\n    except Exception:\n        return {}\n```\n\n### Test Cases\n```python\n# Key test scenarios to implement:\n# 1. Test parsing valid JSON responses with different analysis types\n# 2. Test handling of malformed JSON\n# 3. Test recovery of partial responses\n# 4. Test validation against schemas\n# 5. Test sanitization of potentially harmful content\n# 6. Test handling of unexpected response structures\n```\n</info added on 2025-05-20T06:55:45.282Z>\n\n<info added on 2025-05-20T07:38:09.169Z>\n## Implementation Notes for Error Handling in Response Parsing\n\n### Error Handling Strategy Implementation\n```python\ndef handle_response_errors(raw_response, analysis_type, job_id=None):\n    \"\"\"\n    Comprehensive error handling for API responses with recovery attempts.\n    \n    Args:\n        raw_response (str or dict): Raw API response\n        analysis_type (str): Type of analysis performed\n        job_id (int, optional): Associated job ID for logging\n        \n    Returns:\n        tuple: (success_flag, result_dict or error_message)\n    \"\"\"\n    try:\n        result = parse_analysis_response(raw_response, analysis_type)\n        return True, result\n    except ResponseParsingError as e:\n        logger.error(f\"Parsing error for job {job_id}: {str(e)}\")\n        \n        # Attempt recovery\n        recovered_data = recover_partial_response(raw_response, analysis_type)\n        if recovered_data:\n            logger.warning(f\"Partially recovered data for job {job_id}\")\n            return False, {\n                \"partial_data\": recovered_data,\n                \"error\": str(e),\n                \"status\": \"partial_recovery\"\n            }\n        \n        return False, {\"error\": str(e), \"status\": \"parsing_failed\"}\n    except ResponseValidationError as e:\n        logger.error(f\"Validation error for job {job_id}: {str(e)}\")\n        \n        # Extract what data we can, even if it doesn't match schema\n        if isinstance(raw_response, str):\n            try:\n                data = json.loads(raw_response)\n                return False, {\n                    \"unvalidated_data\": data,\n                    \"error\": str(e),\n                    \"status\": \"validation_failed\"\n                }\n            except:\n                pass\n                \n        return False, {\"error\": str(e), \"status\": \"validation_failed\"}\n```\n\n### Malformed Response Detection\n```python\ndef detect_malformed_response(response_data):\n    \"\"\"\n    Detect common patterns of malformed responses.\n    \n    Args:\n        response_data (dict): Parsed response data\n        \n    Returns:\n        tuple: (is_malformed, issue_description)\n    \"\"\"\n    # Check for empty or null values in required fields\n    if not response_data:\n        return True, \"Empty response data\"\n        \n    # Check for truncated JSON (common with token limits)\n    if isinstance(response_data, str) and response_data.count('{') != response_data.count('}'):\n        return True, \"Truncated JSON structure\"\n        \n    # Check for common error patterns in LLM responses\n    error_patterns = [\n        \"I'm sorry\", \"I apologize\", \"I cannot\", \"As an AI\",\n        \"error\", \"unable to\", \"failed to\"\n    ]\n    \n    if isinstance(response_data, str):\n        lower_response = response_data.lower()\n        for pattern in error_patterns:\n            if pattern.lower() in lower_response:\n                return True, f\"Response contains error indicator: '{pattern}'\"\n                \n    return False, None\n```\n\n### Response Logging System\n```python\ndef log_response_processing(job_id, analysis_type, raw_response, parsed_result, success):\n    \"\"\"\n    Log response processing details for debugging and analytics.\n    \n    Args:\n        job_id (int): Associated job ID\n        analysis_type (str): Type of analysis performed\n        raw_response (str): Raw API response\n        parsed_result (dict): Parsed result or error info\n        success (bool): Whether parsing succeeded\n    \"\"\"\n    # Create log entry with sanitized data\n    log_entry = {\n        \"timestamp\": datetime.now().isoformat(),\n        \"job_id\": job_id,\n        \"analysis_type\": analysis_type,\n        \"success\": success,\n        \"response_size\": len(str(raw_response)),\n        \"result_summary\": {k: \"...\" if k in [\"raw_response\"] else v \n                          for k, v in parsed_result.items()} if isinstance(parsed_result, dict) else str(parsed_result)\n    }\n    \n    # Add error information if available\n    if not success and isinstance(parsed_result, dict) and \"error\" in parsed_result:\n        log_entry[\"error\"] = parsed_result[\"error\"]\n        log_entry[\"status\"] = parsed_result.get(\"status\", \"unknown_error\")\n    \n    # Log to file and/or monitoring system\n    logger.info(f\"Response processing: {json.dumps(log_entry)}\")\n    \n    # Store in database for analytics\n    if settings.STORE_RESPONSE_LOGS:\n        ResponseProcessingLog.create(\n            job_id=job_id,\n            analysis_type=analysis_type,\n            success=success,\n            log_data=log_entry\n        )\n```\n\n### Integration with Main Processing Flow\n```python\n# In src/core/analysis_processor.py\n\ndef process_transcript_with_profile(transcript, profile, job_id=None):\n    # ... existing code ...\n    \n    try:\n        # Get response from API\n        raw_response = api_client.analyze_transcript(transcript, prompt)\n        \n        # Process response with enhanced error handling\n        success, result = handle_response_errors(raw_response, profile.analysis_type_slug, job_id)\n        \n        # Log processing results\n        log_response_processing(job_id, profile.analysis_type_slug, raw_response, result, success)\n        \n        if success:\n            # Create AnalysisResult with validated data\n            analysis_result = AnalysisResult(\n                job_id=job_id,\n                raw_api_response=json.dumps(raw_response) if isinstance(raw_response, dict) else raw_response,\n                sanitized_data=sanitize_response_data(result)\n            )\n            return analysis_result\n        else:\n            # Handle partial or failed results\n            if \"partial_data\" in result:\n                # Create result with partial data and warning flag\n                analysis_result = AnalysisResult(\n                    job_id=job_id,\n                    raw_api_response=json.dumps(raw_response) if isinstance(raw_response, dict) else raw_response,\n                    sanitized_data=sanitize_response_data(result[\"partial_data\"]),\n                    warnings=[result[\"error\"]],\n                    is_complete=False\n                )\n                return analysis_result\n            else:\n                # Update job status and raise exception\n                if job_id:\n                    update_job_status(job_id, \"failed\", error_message=result[\"error\"])\n                raise ResponseProcessingError(result[\"error\"])\n    \n    # ... existing error handling ...\n```\n\n### Unit Test Cases for Error Handling\n```python\ndef test_malformed_json_recovery():\n    \"\"\"Test recovery from malformed JSON responses\"\"\"\n    # Truncated JSON response\n    truncated_response = '{\"sentiment\": \"positive\", \"confidence\": 0.87, \"explanation\": \"The customer expressed satisfaction with'\n    \n    # Test recovery\n    success, result = handle_response_errors(truncated_response, \"sentiment\")\n    assert not success\n    assert \"partial_data\" in result\n    assert result[\"status\"] == \"partial_recovery\"\n    assert \"sentiment\" in result[\"partial_data\"]\n\ndef test_error_pattern_detection():\n    \"\"\"Test detection of error patterns in responses\"\"\"\n    # Response with error pattern\n    error_response = '{\"content\": \"I apologize, but I cannot analyze this transcript due to insufficient context.\"}'\n    \n    # Test detection\n    is_malformed, issue = detect_malformed_response(error_response)\n    assert is_malformed\n    assert \"error indicator\" in issue\n```\n</info added on 2025-05-20T07:38:09.169Z>\n\n<info added on 2025-05-20T09:02:05.572Z>\n## Implementation of Result Storage and Sanitization Integration\n\n### Updated `_create_and_save_result_object` Function\n```python\ndef _create_and_save_result_object(job_id, raw_response, parsed_data, warnings=None):\n    \"\"\"\n    Create and save an AnalysisResult object with sanitized data.\n    \n    Args:\n        job_id (int): The ID of the analysis job\n        raw_response (str or dict): Raw API response\n        parsed_data (dict): Parsed and validated data\n        warnings (list, optional): List of warning messages\n        \n    Returns:\n        AnalysisResult: The created and saved result object\n    \"\"\"\n    # Ensure raw_response is stored as a string\n    if isinstance(raw_response, dict):\n        raw_response_str = json.dumps(raw_response)\n    else:\n        raw_response_str = raw_response\n        \n    # Sanitize the parsed data before storage\n    sanitized_data = sanitize_response_data(parsed_data)\n    \n    # Create the result object\n    result = AnalysisResult(\n        job_id=job_id,\n        raw_api_response=raw_response_str,\n        parsed_data=sanitized_data,\n        warnings=warnings or []\n    )\n    \n    # Save to database\n    result.save()\n    \n    # Update job status to completed\n    update_job_status(job_id, \"completed\")\n    \n    return result\n```\n\n### Integration in Analysis Processor\n```python\n# In src/core/analysis_processor.py\n\ndef process_transcript_with_profile(transcript, profile, job_id=None):\n    # ... existing code ...\n    \n    try:\n        # Get response from API\n        raw_response = api_client.analyze_transcript(transcript, prompt)\n        \n        # Parse and validate the response\n        parsed_data = parse_analysis_response(raw_response, profile.analysis_type_slug)\n        \n        # Create and save result with sanitized data\n        result = _create_and_save_result_object(job_id, raw_response, parsed_data)\n        \n        return result\n    except ResponseParsingError as e:\n        # Attempt recovery with partial data\n        recovered_data = recover_partial_response(raw_response, profile.analysis_type_slug)\n        if recovered_data:\n            logger.warning(f\"Partially recovered data for job {job_id}\")\n            result = _create_and_save_result_object(\n                job_id, \n                raw_response, \n                recovered_data, \n                warnings=[f\"Partial data recovery: {str(e)}\"]\n            )\n            return result\n        \n        # Update job status and re-raise\n        if job_id:\n            update_job_status(job_id, \"failed\", error_message=str(e))\n        raise\n    \n    # ... existing error handling ...\n```\n\n### Helper Functions Implementation in `response_parser.py`\n```python\ndef _parse_text_response(text_content, analysis_type):\n    \"\"\"\n    Parse non-JSON text responses based on analysis type.\n    \n    Args:\n        text_content (str): Text content from API response\n        analysis_type (str): Type of analysis performed\n        \n    Returns:\n        dict: Structured data extracted from text\n    \"\"\"\n    result = {}\n    \n    if analysis_type == \"sentiment\":\n        # Extract sentiment patterns\n        sentiment_match = re.search(r'sentiment[:\\s]+([a-z]+)', text_content, re.IGNORECASE)\n        confidence_match = re.search(r'confidence[:\\s]+([\\d.]+)', text_content, re.IGNORECASE)\n        \n        if sentiment_match:\n            result[\"sentiment\"] = sentiment_match.group(1).lower()\n        \n        if confidence_match:\n            try:\n                result[\"confidence\"] = float(confidence_match.group(1))\n            except ValueError:\n                result[\"confidence\"] = 0.0\n        \n        # Extract explanation (everything after \"explanation:\" if present)\n        explanation_match = re.search(r'explanation[:\\s]+(.*?)(?:\\n\\n|\\Z)', \n                                     text_content, re.IGNORECASE | re.DOTALL)\n        if explanation_match:\n            result[\"explanation\"] = explanation_match.group(1).strip()\n        else:\n            # Use the whole text as explanation if no specific section found\n            result[\"explanation\"] = text_content\n    \n    elif analysis_type == \"topic\":\n        # Extract topics list\n        topics = []\n        topic_section = re.search(r'topics[:\\s]+(.*?)(?:\\n\\n|\\Z)', \n                                 text_content, re.IGNORECASE | re.DOTALL)\n        \n        if topic_section:\n            # Look for list items\n            topic_items = re.findall(r'[-*•]\\s*(.*?)(?:\\n|$)', topic_section.group(1))\n            if topic_items:\n                topics = [item.strip() for item in topic_items]\n            else:\n                # Split by commas or newlines if no list markers\n                topics = [t.strip() for t in re.split(r',|\\n', topic_section.group(1)) if t.strip()]\n        \n        result[\"topics\"] = topics\n    \n    # Add fallback values for required fields if missing\n    if analysis_type == \"sentiment\":\n        if \"sentiment\" not in result:\n            result[\"sentiment\"] = \"neutral\"\n        if \"confidence\" not in result:\n            result[\"confidence\"] = 0.5\n        if \"explanation\" not in result:\n            result[\"explanation\"] = \"No explanation provided\"\n    \n    return result\n\ndef _transform_response(parsed_content, analysis_type):\n    \"\"\"\n    Transform parsed content into standardized format based on analysis type.\n    \n    Args:\n        parsed_content (dict): Parsed content from API response\n        analysis_type (str): Type of analysis performed\n        \n    Returns:\n        dict: Transformed data in standardized format\n    \"\"\"\n    transformed = {}\n    \n    if analysis_type == \"sentiment\":\n        # Standardize sentiment values\n        if \"sentiment\" in parsed_content:\n            sentiment = parsed_content[\"sentiment\"].lower()\n            # Map various sentiment expressions to standard values\n            sentiment_mapping = {\n                \"positive\": [\"positive\", \"good\", \"favorable\", \"happy\", \"satisfied\"],\n                \"negative\": [\"negative\", \"bad\", \"unfavorable\", \"unhappy\", \"dissatisfied\"],\n                \"neutral\": [\"neutral\", \"mixed\", \"balanced\", \"unclear\"]\n            }\n            \n            for standard, variations in sentiment_mapping.items():\n                if sentiment in variations:\n                    transformed[\"sentiment\"] = standard\n                    break\n            else:\n                # Default if no match found\n                transformed[\"sentiment\"] = \"neutral\"\n        \n        # Normalize confidence to 0-1 range\n        if \"confidence\" in parsed_content:\n            confidence = parsed_content[\"confidence\"]\n            if isinstance(confidence, (int, float)):\n                # Ensure value is between 0 and 1\n                transformed[\"confidence\"] = max(0.0, min(1.0, float(confidence)))\n            elif isinstance(confidence, str):\n                # Try to convert string to float\n                try:\n                    confidence_value = float(confidence.strip('%')) / 100 if '%' in confidence else float(confidence)\n                    transformed[\"confidence\"] = max(0.0, min(1.0, confidence_value))\n                except ValueError:\n                    transformed[\"confidence\"] = 0.5\n            else:\n                transformed[\"confidence\"] = 0.5\n        \n        # Copy other fields\n        for field in [\"explanation\", \"key_phrases\"]:\n            if field in parsed_content:\n                transformed[field] = parsed_content[field]\n    \n    # Copy any remaining fields\n    for key, value in parsed_content.items():\n        if key not in transformed:\n            transformed[key] = value\n    \n    return transformed\n```\n</info added on 2025-05-20T09:02:05.572Z>\n\n<info added on 2025-05-20T09:07:44.236Z>\n## Unit Test Implementation for Response Parser\n\n### Test File: `tests/core/test_response_parser.py`\n```python\nimport json\nimport pytest\nfrom unittest.mock import patch, MagicMock\n\nfrom src.core.response_parser import (\n    parse_analysis_response, \n    sanitize_response_data,\n    recover_partial_response,\n    handle_response_errors,\n    detect_malformed_response,\n    ResponseParsingError,\n    ResponseValidationError\n)\n\nclass TestResponseParser:\n    \n    def test_parse_valid_json_response(self):\n        \"\"\"Test parsing a valid JSON response with schema validation.\"\"\"\n        # Mock response from Grok API\n        mock_response = {\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": json.dumps({\n                            \"sentiment\": \"positive\",\n                            \"confidence\": 0.87,\n                            \"explanation\": \"Customer expressed satisfaction\"\n                        })\n                    }\n                }\n            ]\n        }\n        \n        with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {\n            \"sentiment\": {\n                \"type\": \"object\",\n                \"required\": [\"sentiment\", \"confidence\", \"explanation\"],\n                \"properties\": {\n                    \"sentiment\": {\"type\": \"string\"},\n                    \"confidence\": {\"type\": \"number\"},\n                    \"explanation\": {\"type\": \"string\"}\n                }\n            }\n        }):\n            with patch('src.core.response_parser._transform_response', return_value={\n                \"sentiment\": \"positive\",\n                \"confidence\": 0.87,\n                \"explanation\": \"Customer expressed satisfaction\"\n            }):\n                result = parse_analysis_response(mock_response, \"sentiment\")\n                \n                assert result[\"sentiment\"] == \"positive\"\n                assert result[\"confidence\"] == 0.87\n                assert result[\"explanation\"] == \"Customer expressed satisfaction\"\n    \n    def test_parse_response_without_schema(self):\n        \"\"\"Test parsing when no schema exists for the analysis type.\"\"\"\n        mock_response = {\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": json.dumps({\n                            \"custom_field\": \"value\"\n                        })\n                    }\n                }\n            ]\n        }\n        \n        with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {}):\n            with patch('src.core.response_parser._transform_response', return_value={\"custom_field\": \"value\"}):\n                result = parse_analysis_response(mock_response, \"custom_type\")\n                assert result[\"custom_field\"] == \"value\"\n    \n    def test_parse_direct_content(self):\n        \"\"\"Test parsing when content is directly in the response.\"\"\"\n        mock_response = {\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": {\n                            \"sentiment\": \"positive\",\n                            \"confidence\": 0.87\n                        }\n                    }\n                }\n            ]\n        }\n        \n        with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {}):\n            with patch('src.core.response_parser._transform_response', \n                      return_value={\"sentiment\": \"positive\", \"confidence\": 0.87}):\n                result = parse_analysis_response(mock_response, \"sentiment\")\n                assert result[\"sentiment\"] == \"positive\"\n                assert result[\"confidence\"] == 0.87\n    \n    def test_parse_non_json_content(self):\n        \"\"\"Test parsing text content that isn't JSON.\"\"\"\n        mock_response = {\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": \"Sentiment: positive\\nConfidence: 0.87\\nExplanation: Customer was happy\"\n                    }\n                }\n            ]\n        }\n        \n        with patch('src.core.response_parser._parse_text_response', \n                  return_value={\"sentiment\": \"positive\", \"confidence\": 0.87, \"explanation\": \"Customer was happy\"}):\n            with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {}):\n                with patch('src.core.response_parser._transform_response', \n                          lambda x, y: x):  # Just return the input\n                    result = parse_analysis_response(mock_response, \"sentiment\")\n                    assert result[\"sentiment\"] == \"positive\"\n                    assert result[\"confidence\"] == 0.87\n    \n    def test_parse_json_string_input(self):\n        \"\"\"Test parsing when input is a JSON string.\"\"\"\n        mock_response = json.dumps({\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": json.dumps({\n                            \"sentiment\": \"positive\",\n                            \"confidence\": 0.87\n                        })\n                    }\n                }\n            ]\n        })\n        \n        with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {}):\n            with patch('src.core.response_parser._transform_response', \n                      lambda x, y: x):  # Just return the input\n                result = parse_analysis_response(mock_response, \"sentiment\")\n                assert result[\"sentiment\"] == \"positive\"\n                assert result[\"confidence\"] == 0.87\n    \n    def test_parse_malformed_json(self):\n        \"\"\"Test handling of malformed JSON.\"\"\"\n        mock_response = {\n            \"choices\": [\n                {\n                    \"message\": {\n                        \"content\": \"{ this is not valid JSON }\"\n                    }\n                }\n            ]\n        }\n        \n        with patch('src.core.response_parser._parse_text_response', \n                  return_value={\"sentiment\": \"neutral\", \"confidence\": 0.5}):\n            with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {}):\n                with patch('src.core.response_parser._transform_response', \n                          lambda x, y: x):\n                    result = parse_analysis_response(mock_response, \"sentiment\")\n                    assert result[\"sentiment\"] == \"neutral\"\n                    assert result[\"confidence\"] == 0.5\n    \n    def test_parse_missing_grok_structure(self):\n        \"\"\"Test handling when Grok API response structure is missing.\"\"\"\n        mock_response = {\"invalid_structure\": True}\n        \n        with pytest.raises(ResponseParsingError):\n            parse_analysis_response(mock_response, \"sentiment\")\n    \n    def test_sanitize_response_data(self):\n        \"\"\"Test sanitization of response data.\"\"\"\n        test_data = {\n            \"HTML<script>alert('xss')</script>\": \"value with <tags>\",\n            \"nested\": {\n                \"key\": \"<img src=x onerror=alert('XSS')>\",\n                \"list\": [\"safe\", \"<script>alert('xss')</script>\"]\n            }\n        }\n        \n        result = sanitize_response_data(test_data)\n        \n        # Check that keys are sanitized\n        assert \"html_script_alert_xss_script_\" in result\n        \n        # Check that values are HTML escaped\n        assert \"&lt;tags&gt;\" in result[\"html_script_alert_xss_script_\"]\n        assert \"&lt;img src=x onerror=alert(&#x27;XSS&#x27;)&gt;\" in result[\"nested\"][\"key\"]\n        assert \"&lt;script&gt;alert(&#x27;xss&#x27;)&lt;/script&gt;\" in result[\"nested\"][\"list\"][1]\n    \n    def test_recover_partial_response(self):\n        \"\"\"Test recovery of partial response from text.\"\"\"\n        # Text with embedded JSON\n        text_with_json = \"Some text before {\\\"sentiment\\\": \\\"positive\\\", \\\"confidence\\\": 0.8} and after\"\n        \n        with patch('src.core.response_parser.ANALYSIS_SCHEMAS', {\n            \"sentiment\": {\n                \"required\": [\"sentiment\", \"confidence\", \"explanation\"]\n            }\n        }):\n            result = recover_partial_response(text_with_json, \"sentiment\")\n            \n            assert \"recovered_data\" in result\n            assert result[\"recovered_data\"][\"sentiment\"] == \"positive\"\n            assert result[\"is_complete\"] is False\n            assert \"explanation\" in result[\"missing_fields\"]\n    \n    def test_recover_no_json(self):\n        \"\"\"Test recovery when no JSON is found.\"\"\"\n        text_without_json = \"This text contains no valid JSON structures\"\n        \n        result = recover_partial_response(text_without_json, \"sentiment\")\n        assert result == {}\n    \n    def test_handle_response_errors_success(self):\n        \"\"\"Test error handling when parsing succeeds.\"\"\"\n        with patch('src.core.response_parser.parse_analysis_response', \n                  return_value={\"sentiment\": \"positive\"}):\n            success, result = handle_response_errors(\"mock_response\", \"sentiment\")\n            \n            assert success is True\n            assert result[\"sentiment\"] == \"positive\"\n    \n    def test_handle_response_errors_parsing_error_with_recovery(self):\n        \"\"\"Test error handling when parsing fails but recovery succeeds.\"\"\"\n        with patch('src.core.response_parser.parse_analysis_response', \n                  side_effect=ResponseParsingError(\"Parsing failed\")):\n            with patch('src.core.response_parser.recover_partial_response', \n                      return_value={\"sentiment\": \"positive\"}):\n                success, result = handle_response_errors(\"mock_response\", \"sentiment\")\n                \n                assert success is False\n                assert \"partial_data\" in result\n                assert result[\"status\"] == \"partial_recovery\"\n    \n    def test_handle_response_errors_parsing_error_no_recovery(self):\n        \"\"\"Test error handling when parsing fails and recovery fails.\"\"\"\n        with patch('src.core.response_parser.parse_analysis_response', \n                  side_effect=ResponseParsingError(\"Parsing failed\")):\n            with patch('src.core.response_parser.recover_partial_response', \n                      return_value={}):\n                success, result = handle_response_errors(\"mock_response\", \"sentiment\")\n                \n                assert success is False\n                assert \"error\" in result\n                assert result[\"status\"] == \"parsing_failed\"\n    \n    def test_detect_malformed_response_empty(self):\n        \"\"\"Test detection of empty response.\"\"\"\n        is_malformed, issue = detect_malformed_response({})\n        assert is_malformed is True\n        assert \"Empty response\" in issue\n    \n    def test_detect_malformed_response_truncated(self):\n        \"\"\"Test detection of truncated JSON.\"\"\"\n        is_malformed, issue = detect_malformed_response(\"{\\\"key\\\": \\\"value\\\"\")\n        assert is_malformed is True\n        assert \"Truncated JSON\" in issue\n    \n    def test_detect_malformed_response_error_pattern(self):\n        \"\"\"Test detection of error patterns in response.\"\"\"\n        is_malformed, issue = detect_malformed_response(\"I'm sorry, I cannot analyze this text\")\n        assert is_malformed is True\n        assert \"error indicator\" in issue\n    \n    def test_detect_malformed_response_valid(self):\n        \"\"\"Test detection with valid response.\"\"\"\n        is_malformed, issue = detect_malformed_response({\"sentiment\": \"positive\", \"confidence\": 0.8})\n        assert is_malformed is False\n        assert issue is None\n```\n</info added on 2025-05-20T09:07:44.236Z>",
